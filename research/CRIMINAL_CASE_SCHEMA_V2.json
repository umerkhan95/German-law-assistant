{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pakistani Criminal Case — Qdrant Payload Schema v2",
  "description": "Validated against 5 real SC judgments, CrPC Section 367, and international legal AI standards. 85 fields, all extractable from judgment text.",
  "type": "object",
  "required": ["case_id", "case_number", "court_name", "court_level", "date_judgment", "judge_names"],
  "properties": {

    "_comment_tier1": "=== TIER 1: CORE IDENTIFICATION (always extractable) ===",
    "case_id": { "type": "string", "description": "Deterministic hash: {court_code}:{year}:{case_number}" },
    "case_number": { "type": "string", "description": "Official court number", "examples": ["Cr. Appeal No. 123/2023"] },
    "case_title": { "type": "string", "description": "Party names", "examples": ["State v. Muhammad Ahmed Khan"] },
    "case_type": { "type": "string", "enum": ["trial", "appeal", "revision", "reference", "suo_motu", "petition", "contempt", "implementation"] },
    "judgment_type": { "type": "string", "enum": ["conviction", "acquittal", "partial_conviction", "dismissal", "remand", "sentence_modified", "monitoring_order"] },
    "date_judgment": { "type": "string", "format": "date" },
    "date_incident": { "type": "string", "format": "date", "description": "When the crime occurred" },
    "date_fir": { "type": "string", "format": "date", "description": "When FIR was lodged" },
    "date_filed": { "type": "string", "format": "date", "description": "When case/appeal was filed" },
    "court_level": { "type": "string", "enum": ["trial_court", "high_court", "supreme_court", "special_court", "federal_shariat", "anti_terrorism_court"] },
    "court_name": { "type": "string", "examples": ["Lahore High Court", "ATC Karachi", "Supreme Court of Pakistan"] },
    "judge_names": { "type": "array", "items": { "type": "string" }, "description": "All judges on bench" },
    "jurisdiction_province": { "type": "string", "enum": ["punjab", "sindh", "kpk", "balochistan", "islamabad", "federal"] },

    "_comment_tier2": "=== TIER 2: OFFENSE & CHARGES ===",
    "ppc_sections": { "type": "array", "items": { "type": "integer" }, "description": "PPC sections charged", "examples": [[302, 34]] },
    "offense_category": { "type": "string", "enum": ["person", "property", "state", "religion", "public_health"] },
    "severity_level": { "type": "string", "enum": ["capital", "life", "long_term_7plus", "medium_3to7", "short_under3"] },
    "special_law": { "type": "string", "enum": ["anti_terrorism", "cnsa", "hudood", "juvenile", "contempt", "nab", "cyber", "none"] },
    "motive_category": { "type": "string", "description": "Free text keyword, not strict enum", "examples": ["property_dispute", "family_enmity", "honor", "political"] },
    "section_34_applied": { "type": "boolean", "description": "Common intention applied" },
    "forum_category": { "type": "string", "examples": ["murder", "theft", "sexual_assault", "terrorism", "drug_trafficking", "financial", "contempt", "corruption"] },

    "_comment_tier3": "=== TIER 3: PARTIES ===",
    "accused_name": { "type": "string" },
    "accomplices_count": { "type": "integer" },
    "victim_name": { "type": "string" },
    "victim_relationship": { "type": "string", "enum": ["spouse", "child", "parent", "sibling", "employer", "servant", "stranger", "other"] },
    "complainant_name": { "type": "string" },
    "fir_number": { "type": "string", "examples": ["FIR No. 73/2021"] },
    "police_station": { "type": "string" },
    "prosecuting_agency": { "type": "string", "enum": ["police", "nab", "anti_corruption", "counter_terrorism", "fbi_equiv"] },
    "prosecutor_name": { "type": "string" },
    "defense_counsel": { "type": "string" },

    "_comment_tier4": "=== TIER 4: EVIDENCE INDICATORS ===",
    "weapon_recovered": { "type": "boolean" },
    "weapon_type": { "type": "string", "enum": ["firearm", "knife", "blunt", "poison", "explosive", "none"] },
    "forensic_evidence_types": { "type": "array", "items": { "type": "string", "enum": ["dna", "fingerprint", "ballistics", "toxicology", "trace"] } },
    "dna_tested": { "type": "boolean" },
    "dna_matched_accused": { "type": "boolean" },
    "ballistics_matched": { "type": "boolean" },
    "post_mortem_done": { "type": "boolean" },
    "cause_of_death_established": { "type": "string", "enum": ["confirmed", "probable", "undetermined"] },
    "medical_evidence_present": { "type": "boolean" },
    "documentary_evidence_types": { "type": "array", "items": { "type": "string", "enum": ["fir", "pm_report", "medical", "bank", "call_records", "recovery_memo", "forged_document"] } },
    "chain_of_custody_intact": { "type": "boolean" },
    "recovery_witnesses_examined": { "type": "string", "enum": ["both", "one", "neither"] },
    "evidence_classification": { "type": "string", "enum": ["direct", "mostly_direct", "mostly_circumstantial", "wholly_circumstantial"] },

    "_comment_tier5": "=== TIER 5: WITNESS SUMMARY ===",
    "prosecution_witness_count": { "type": "integer" },
    "defense_witness_count": { "type": "integer" },
    "eyewitness_count": { "type": "integer" },
    "expert_witness_present": { "type": "boolean" },
    "hostile_witness_declared": { "type": "boolean" },
    "witness_impeached": { "type": "boolean" },
    "accomplice_witness": { "type": "boolean" },
    "dying_declaration_exists": { "type": "boolean" },

    "_comment_tier6": "=== TIER 6: PROCEDURAL ISSUES ===",
    "fir_delay_hours": { "type": "integer", "description": "Hours between incident and FIR lodging" },
    "investigation_quality": { "type": "string", "enum": ["thorough", "adequate", "defective", "highly_defective"] },
    "arrest_lawful": { "type": "boolean" },
    "police_malpractice_alleged": { "type": "boolean" },
    "torture_allegations": { "type": "boolean" },
    "section_161_recorded": { "type": "boolean", "description": "Police witness statements recorded" },
    "section_164_recorded": { "type": "boolean", "description": "Judicial confession/statement recorded" },
    "search_warrant_obtained": { "type": "boolean" },
    "alibi_raised": { "type": "boolean" },

    "_comment_tier7": "=== TIER 7: SENTENCING & OUTCOME ===",
    "sentence_type": { "type": "string", "enum": ["death", "life", "rigorous", "simple", "fine_only", "acquitted"] },
    "sentence_total_months": { "type": "integer", "description": "Total imprisonment in months" },
    "fine_amount_pkr": { "type": "integer" },
    "sentence_modified_to": { "type": "string", "description": "If altered on appeal", "examples": ["death_to_life", "life_to_14years"] },
    "aggravating_factors": { "type": "array", "items": { "type": "string" }, "examples": [["premeditation", "vulnerable_victim", "brutality"]] },
    "mitigating_factors": { "type": "array", "items": { "type": "string" }, "examples": [["first_offense", "young_age", "provocation"]] },
    "diyat_compromise": { "type": "boolean", "description": "Murder compounded by legal heirs (PPC 309-310)" },
    "section_382b_benefit": { "type": "boolean", "description": "Pre-trial custody credited to sentence" },
    "benefit_of_doubt_applied": { "type": "boolean" },

    "_comment_tier8": "=== TIER 8: APPEAL & CASE LINKAGE ===",
    "lower_court_case_number": { "type": "string" },
    "lower_court_name": { "type": "string" },
    "lower_court_judgment_date": { "type": "string", "format": "date" },
    "appeal_outcome": { "type": "string", "enum": ["allowed", "dismissed", "partially_allowed", "remanded"] },
    "precedents_cited": { "type": "array", "items": { "type": "string" }, "description": "Case citations relied upon", "examples": [["PLD 2020 SC 456", "2019 SCMR 789"]] },
    "statutes_discussed": { "type": "array", "items": { "type": "string" }, "description": "All statutes/provisions discussed", "examples": [["PPC 302", "CrPC 367", "Qanun-e-Shahadat Art. 135"]] },
    "constitutional_articles": { "type": "array", "items": { "type": "string" }, "examples": [["184(3)", "199", "10-A"]] },
    "parallel_citations": { "type": "array", "items": { "type": "string" }, "description": "Official reporter citations for this case" },
    "source_url": { "type": "string", "format": "uri" },
    "reporting_status": { "type": "string", "enum": ["approved", "not_approved", "unknown"] }
  }
}
